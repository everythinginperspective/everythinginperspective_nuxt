e":"Urban efficiency (optimized transit)"}]},{"type":"element","tag":"li","props":{},"children":[{"type":"text","value":"Safety (emergency response)"}]}]},{"type":"element","tag":"p","props":{},"children":[{"type":"text","value":"But the cost:"}]},{"type":"element","tag":"ul","props":{},"children":[{"type":"element","tag":"li","props":{},"children":[{"type":"text","value":"Surveillance (government can track anyone)"}]},{"type":"element","tag":"li","props":{},"children":[{"type":"text","value":"Chilling effects (behavior modification from being watched)"}]},{"type":"element","tag":"li","props":{},"children":[{"type":"text","value":"Discrimination (location history used against you)"}]},{"type":"element","tag":"li","props":{},"children":[{"type":"text","value":"Manipulation (targeted ads/content based on behavior)"}]}]},{"type":"element","tag":"p","props":{},"children":[{"type":"element","tag":"strong","props":{},"children":[{"type":"text","value":"The tradeoff is not disclosed."}]},{"type":"text","value":" Users are told \"location data improves your navigation.\" They're not told \"location data enables government surveillance and behavioral manipulation.\""}]},{"type":"element","tag":"h2","props":{"id":"the-technical-reality-why-anonymization-doesnt-work"},"children":[{"type":"text","value":"The Technical Reality: Why \"Anonymization\" Doesn't Work"}]},{"type":"element","tag":"p","props":{},"children":[{"type":"text","value":"Google claims much location data is \"anonymized.\""}]},{"type":"element","tag":"p","props":{},"children":[{"type":"element","tag":"strong","props":{},"children":[{"type":"text","value":"Reality of anonymization:"}]}]},{"type":"element","tag":"ul","props":{},"children":[{"type":"element","tag":"li","props":{},"children":[{"type":"text","value":"Original data: Your location history"}]},{"type":"element","tag":"li","props":{},"children":[{"type":"text","value":"Anonymization: Remove name, account ID"}]},{"type":"element","tag":"li","props":{},"c
"}]},{"type":"element","tag":"li","props":{},"children":[{"type":"text","value":"Religion: 78% accuracy"}]},{"type":"element","tag":"li","props":{},"children":[{"type":"text","value":"Political affiliation: 72%"}]},{"type":"element","tag":"li","props":{},"children":[{"type":"text","value":"Sexual orientation: 65% accuracy"}]},{"type":"element","tag":"li","props":{},"children":[{"type":"text","value":"Income bracket: 61%"}]}]},{"type":"element","tag":"p","props":{},"children":[{"type":"element","tag":"strong","props":{},"children":[{"type":"text","value":"Key point:"}]},{"type":"text","value":" Google doesn't explicitly collect all this data. They infer it from behavioral patterns."}]},{"type":"element","tag":"h3","props":{"id":"who-has-access"},"children":[{"type":"text","value":"Who Has Access"}]},{"type":"element","tag":"p","props":{},"children":[{"type":"element","tag":"strong","props":{},"children":[{"type":"text","value":"Direct access (Google knows this):"}]}]},{"type":"element","tag":"ul","props":{},"children":[{"type":"element","tag":"li","props":{},"children":[{"type":"text","value":"Google internally (all of it)"}]},{"type":"element","tag":"li","props":{},"children":[{"type":"text","value":"Law enforcement (subpoena, warrant, data request)"}]},{"type":"element","tag":"li","props":{},"children":[{"type":"text","value":"Advertisers (anonymized, aggregated)"}]},{"type":"element","tag":"li","props":{},"children":[{"type":"text","value":"Google business partners (limited access)"}]}]},{"type":"element","tag":"p","props":{},"children":[{"type":"element","tag":"strong","props":{},"children":[{"type":"text","value":"Indirect access (Google less transparent about):"}]}]},{"type":"element","tag":"ul","props":{},"children":[{"type":"element","tag":"li","props":{},"children":[{"type":"text","value":"Government (data requests, sometimes without warrant)"}]},{"type":"element","tag":"li","props":{},"children":[{"type":"text","value":"Insurance companies (can infer location data from app usage)"}]},{"type":"element","tag":"li","props":{},"children":[{"type":"text","value":"Ex-partners/stalkers (can request location history through account access)"}]},{"type":"element","tag":"li","props":{},"children":[{"type":"text","value":"Researchers (aggregated data through datasets)"}]}]},{"type":"element","tag":"p","props":{},"children":[{"type":"element","tag":"strong","props":{},"children":[{"type":"text","value":"Famous examples:"}]}]},{"type":"element","tag":"ul","props":{},"children":[{"type":"element","tag":"li","props":{},"children":[{"type":"text","value":"2019: NYPD used Google location data to identify protesters"}]},{"type":"element","tag":"li","props":{},"children":[{"type":"text","value":"2020: ICE used location data to find undocumented immigrants"}]},{"type":"element","tag":"li","props":{},"children":[{"type":"text","value":"2021: Prosecutors used Google location data to find suspects near crimes"}]},{"type":"element","tag":"li","props":{},"children":[{"type":"text","value":"2023: Data brokers sold Google location inferences to advertisers"}]}]},{"type":"element","tag":"h3","props":{"id":"consent-problem"},"children":[{"type":"text","value":"Consent Problem"}]},{"type":"element","tag":"p","props":{},"children":[{"type":"text","value":"Google's privacy consent:"}]},{"type":"element","tag":"ul","props":{},"children":[{"type":"element","tag":"li","props":{},"children":[{"type":"text","value":"Default: Location tracking enabled"}]},{"type":"element","tag":"li","props":{},"children":[{"type":"text","value":"Opt-out: Available, but hidden in settings"}]},{"type":"element","tag":"li","props":{},"children":[{"type":"text","value":"Language: Vague (\"to improve your experience\")"}]},{"type":"element","tag":"li","props":{},"children":[{"type":"text","value":"Frequency: Users re-enabled after updates (dark pattern)"}]}]},{"type":"element","tag":"p","props":{},"children":[{"type":"element","tag":"strong","props":{},"children":[{"type":"text","value":"Research (2024):"}]},{"type":"text","value":" 73% of Google Maps users think location tracking is off when it's actually on."}]},{"type":"element","tag":"p","props":{},"children":[{"type":"element","tag":"strong","props":{},"children":[{"type":"text","value":"Reality:"}]},{"type":"text","value":" Consent is illusory when most people don't know they've consented."}]},{"type":"element","tag":"h2","props":{"id":"what-location-data-is-used-for-and-why-it-matters"},"children":[{"type":"text","value":"What Location Data Is Used For (And Why It Matters)"}]},{"type":"element","tag":"h3","props":{"id":"law-enforcement-known-uses"},"children":[{"type":"text","value":"Law Enforcement (Known Uses)"}]},{"type":"element","tag":"ul","props":{},"children":[{"type":"element","tag":"li","props":{},"children":[{"type":"text","value":"Suspects: Identify people near crime scenes"}]},{"type":"element","tag":"li","props":{},"children":[{"type":"text","value":"Protesters: Track protest participants"}]},{"type":"element","tag":"li","props":{},"children":[{"type":"text","value":"Immigrants: ICE uses location data to find undocumented immigrants"}]},{"type":"element","tag":"li","props":{},"children":[{"type":"text","value":"Political opposition: Authoritarian governments use location data against activists"}]}]},{"type":"element","tag":"p","props":{},"children":[{"type":"element","tag":"strong","props":{},"children":[{"type":"text","value":"Case example (2020):"}]},{"type":"text","value":" George Floyd protests. Police used Google location data to identify and arrest protesters weeks later."}]},{"type":"element","tag":"p","props":{},"children":[{"type":"element","tag":"strong","props":{},"children":[{"type":"text","value":"Implication:"}]},{"type":"text","value":" Your location history is evidence against you."}]},{"type":"element","tag":"h3","props":{"id":"marketing-and-manipulation"},"children":[{"type":"text","value":"Marketing and Manipulation"}]},{"type":"element","tag":"ul","props":{},"children":[{"type":"element","tag":"li","props":{},"children":[{"type":"text","value":"Advertisers can target based on location history"}]},{"type":"element","tag":"li","props":{},"children":[{"type":"text","value":"Example: Show ads for rehab centers to people visiting bars frequently"}]},{"type":"element","tag":"li","props":{},"children":[{"type":"text","value":"Example: Show ads for fertility clinics to women visiting hospitals"}]},{"type":"element","tag":"li","props":{},"children":[{"type":"text","value":"Example: Show political ads to people near opposition rallies"}]}]},{"type":"element","tag":"p","props":{},"children":[{"type":"element","tag":"strong","props":{},"children":[{"type":"text","value":"Psychological impact:"}]},{"type":"text","value":" Targeted ads based on inferred health conditions/behaviors create chilling effects (people modify behavior if they know they're tracked)."}]},{"type":"element","tag":"h3","props":{"id":"insurance-and-employment"},"children":[{"type":"text","value":"Insurance and Employment"}]},{"type":"element","tag":"ul","props":{},"children":[{"type":"element","tag":"li","props":{},"children":[{"type":"text","value":"Insurance companies can infer health conditions from location history (visits to hospitals)"}]},{"type":"element","tag":"li","props":{},"children":[{"type":"text","value":"Employers can infer employee activities (visits to bars, job interviews at competitors)"}]},{"type":"element","tag":"li","props":{},"children":[{"type":"text","value":"Financial companies can infer income from neighborhood patterns"}]}]},{"type":"element","tag":"p","props":{},"children":[{"type":"element","tag":"strong","props":{},"children":[{"type":"text","value":"Example:"}]},{"type":"text","value":" Insurance company denies claim based on location history showing you at risky locations."}]},{"type":"element","tag":"p","props":{},"children":[{"type":"element","tag":"strong","props":{},"children":[{"type":"text","value":"Legal status:"
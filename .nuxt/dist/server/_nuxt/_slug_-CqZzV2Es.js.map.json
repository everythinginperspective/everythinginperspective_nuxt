bs\nwatch(() => page.value, (newPage) => {\n  if (newPage) {\n    useSeoMeta({\n      title: `${newPage.title} | Everything in Perspective`,\n      description: newPage.description || newPage.title\n    })\n    \n    useHead({\n      script: [\n        {\n          type: 'application/ld+json',\n          innerHTML: JSON.stringify({\n            '@context': 'https://schema.org',\n            '@type': 'BreadcrumbList',\n            itemListElement: [\n              {\n                '@type': 'ListItem',\n                position: 1,\n                name: 'Home',\n                item: 'https://einp.surge.sh'\n              },\n              {\n                '@type': 'ListItem',\n                position: 2,\n                name: newPage.title,\n                item: `https://einp.surge.sh/page/${slug}`\n              }\n            ]\n          })\n        }\n      ]\n    })\n  }\n}, { immediate: true })\n</script>\n\n<style scoped>\n.prose :deep(p) {\n  margin-bottom: 1.5rem;\n  line-height: 1.7;\n}\n.prose :deep(h2) {\n  margin-top: 2rem;\n  margin-bottom: 1rem;\n  font-size: 1.5rem;\n}\n</style>\n"],"version":3}
AAG,OAAK,QAAA,QAAQ,KAAK;;;;AAEG,YAAA,kEAAAD,eAAA,QAAA,QAAQ,KAAK,CAAA,OAAA;AACtD,UAAA,QAAA,QAAQ,MAAI;AAAqC,cAAA,sDAAAA,eAAA,QAAA,QAAQ,IAAI,CAAA,MAAA;AAAA;;;AAC3D,UAAA,QAAA,QAAQ,QAAM;;YACd,QAAA,QAAQ,OAAO,SAAO;AAAG,gBAAA,KAAAE,cAAA,QAAM,QAAA,QAAQ,OAAO,OAAO,CAAA,kEAAA;AAAA;;;YACrD,QAAA,QAAQ,OAAO,UAAQ;AAAG,gBAAA,KAAAA,cAAA,QAAM,QAAA,QAAQ,OAAO,QAAQ,CAAA,mEAAA;AAAA;;;YACvD,QAAA,QAAQ,OAAO,SAAO;AAAG,gBAAA,KAAAA,cAAA,QAAM,QAAA,QAAQ,OAAO,OAAO,CAAA,kEAAA;AAAA;;;;;;;;AAM9C,YAAAD,mBAAA,4BAAA,EAAA,OAAO,QAAA,QAAA,GAAO,MAAA,OAAA,CAAA;AAM8B,YAAA,mOAAAD,eAAA,QAAA,QAAQ,KAAK,CAAA,oCAAA;AAAA;;;;;;;;;;;;;;;;;;;0PCnBzBA,eAAA,QAAA,QAAQ,KAAK;AACtD,UAAA,QAAA,QAAQ,MAAI;AAAwE,cAAA,yFAAAA,eAAA,QAAA,QAAQ,IAAI,CAAA,MAAA;AAAA;;;;AAKvF,YAAAC,mBAAA,4BAAA,EAAA,OAAO,QAAA,QAAA,GAAO,MAAA,OAAA,CAAA;AAK4B,YAAA,iJAAAD,eAAA,QAAA,QAAQ,KAAK,CAAA,sJAAA;AAAA;;;;;;;;;;;;;;;ACQ/E,UAAA,QAAA,SAAA;AACA,UAAA,OAAA,MAAA,OAAA;AACA,UAAA,OAAA,MAAA,OAAA;AAGA,UAAA,eAAA,CAAA,QAAA,SAAA,IAAAG,iBAAA,MAAA,yBAAA,IAAA,CAAA,GAAA,SAAA,MAAA,QAAA,UAAA,GAAA;AACA,QAAA,CAAA,aAAA;AACE,YAAA,YAAA,EAAA,YAAA,KAAA,SAAA,yBAAA,CAAA;AAAA,IAAwE;AAI1E,UAAA,EAAA,MAAA,aAAA,CAAA,QAAA,SAAA,IAAAA,iBAAA,MAAA;AAAA,MAAgC,GAAA,IAAA,IAAA,IAAA;AAAA,MACf,MAAA,aAAA,IAAA,YAAA,MAAA,IAAA,IAAA,EAAA,EAAA,QAAA;AAAA,IAC8C,CAAA,GAAA,SAAA,MAAA,QAAA,UAAA,GAAA;AAI/D,UAAA,cAAA;AAAA,MAAyC,SAAA;AAAA,MAC9B,aAAA;AAAA,MACI,MAAA;AAAA,MACP,MAAA;AAAA,MACA,QAAA;AAAA,MACE,UAAA;AAAA,IACE;AAGZ,UAAA,oBAAA,SAAA,MAAA;AACE,aAAA,YAAA,IAAA,KAAA;AAAA,IAA4B,CAAA;AAI9B,UAAA,MAAA,QAAA,OAAA,CAAA,eAAA;AACE,UAAA,YAAA;AACE,cAAA,WAAA,WAAA,SAAA;AACA,cAAA,gBAAA,WAAA,OAAA,IAAA,KAAA,WAAA,IAAA,EAAA,YAAA,KAAA,oBAAA,KAAA,GAAA,YAAA;AAEA,gBAAA;AAAA,UAAA,OAAA,GAAA,WAAA,KAAA;AAAA,UAAA,MAAA;AAAA,YAAA,EAAA,MAAA,eAAA,SAAA,WAAA,YAAA;AAAA,YAAA,EAAA,UAAA,YAAA,SAAA,WAAA,MAAA;AAAA,YAAA,EAAA,UAAA,kBAAA,SAAA,WAAA,YAAA;AAAA,YAAA,EAAA,UAAA,WAAA,SAAA,SAAA,aAAA,SAAA,gBAAA,YAAA,UAAA;AAAA,YAAA,EAAA,UAAA,YAAA,SAAA,SAAA;AAAA,YAAA,EAAA,UAAA,gBAAA,SAAA,WAAA,YAAA,WAAA,MAAA;AAAA,YAAA,EAAA,MAAA,gBAAA,SAAA,sBAAA;AAAA,YAAA,EAAA,MAAA,iBAAA,SAAA,SAAA;AAAA,UAAA;AAAA,QAAA,CAAA;AAaA,cAAA,aAAA,SAAA,aAAA,SAAA,gBAAA,gBAAA,SAAA,SAAA,SAAA,SAAA,WAAA,WAAA;AAIA,gBAAA;AAAA,UAAQ,QAAA;AAAA,YACE;AAAA,cACN,MAAA;AAAA,cACQ,WAAA,KAAA,UAAA;AAAA,gBACoB,YAAA;AAAA,gBACZ,SAAA;AAAA,gBACH,UAAA,WAAA;AAAA,gBACY,aAAA,WAAA;AAAA,gBACG,OAAA;AAAA,gBACjB,QAAA,WAAA,SAAA;AAAA,kBACqB,SAAA;AAAA,kBACjB,MAAA,WAAA;AAAA,gBACQ,IAAA;AAAA,gBACf,WAAA;AAAA,kBACO,SAAA;AAAA,kBACA,MAAA;AAAA,kBACH,MAAA;AAAA,oBACA,SAAA;AAAA,oBACK,KAAA;AAAA,oBACJ,OAAA;AAAA,oBACE,QAAA;AAAA,kBACC;AAAA,gBACV;AAAA,gBACF,eAAA;AAAA,gBACe,cAAA;AAAA,cACD,CAAA;AAAA,YACf;AAAA,UACH;AAAA,QACF,CAAA;AAAA,MACD;AAAA,IACH,GAAA,EAAA,WAAA,MAAA;;AA1GM,YAAA,QAAAC,eAAAC,WAAA,EAAA,OAAA,mDAAA,MAAA,CAAA,CAAA,GAAA;;;;;;;;;;;;;;;;;;","names":["_ssrInterpolate","_ssrRenderComponent","_ssrRenderAttr","_withAsyncContext","_ssrRenderAttrs","_mergeProps"],"sources":["../../../../components/magazine/ArticleTemplate.vue","../../../../components/magazine/PerspectiveTemplate.vue","../../../../components/magazine/BookTemplate.vue","../../../../components/magazine/PageTemplate.vue","../../../../components/magazine/PersonTemplate.vue","../../../../components/magazine/LanguageTemplate.vue","../../../../pages/magazine/[type]/[slug].vue"],"sourcesContent":["<template>\n  <div>\n    <!-- Article Metadata -->\n    <div class=\"mb-12 pb-8 border-b border-accent\">\n      <h1 class=\"font-serif text-5xl font-bold mb-4 leading-tight\">{{ content.title }}</h1>\n      <div class=\"flex justify-between items-baseline\">\n        <div>\n          <p class=\"text-muted text-sm mb-2\">By <span class=\"font-bold\">{{ content.author || 'Staff' }}</span></p>\n          <p class=\"text-muted text-sm\">{{ formatDate(content.date) }}</p>\n        </div>\n        <span class=\"bg-light text-xs px-3 py-1 font-sans\">{{ content.category || 'General' }}</span>\n      </div>\n    </div>\n\n    <!-- Article Content -->\n    <div class=\"article-content prose prose-lg max-w-none mb-16\">\n      <ContentRenderer :value=\"content\" />\n    </div>\n\n    <!-- Article Footer -->\n    <div class=\"mt-16 pt-8 border-t border-accent\">\n      <div class=\"bg-light p-8 rounded\">\n        <h3 class=\"font-serif text-lg font-bold mb-3\">About the Author</h3>\n        <p class=\"text-sm text-muted\">{{ content.authorBio || `${content.author || 'Staff'} is a writer exploring context, nuance, and perspective on global trends and ideas.` }}</p>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script setup lang=\"ts\">\ndefineProps<{\n  content: any\n}>()\n\nconst formatDate = (date: string) => {\n  if (!date) return ''\n  return new Date(date).toLocaleDateString('en-US', { \n    year: 'numeric', \n    month: 'long', \n    day: 'numeric' \n  })\n}\n</script>\n\n<style scoped>\n.border-accent {\n  border-color: #1a1a1a;\n}\n.text-muted {\n  color: #666666;\n}\n.bg-light {\n  background-color: #F5F5F5;\n}\n.article-content {\n  line-height: 1.7;\n}\n.article-content :deep(p) {\n  margin-bottom: 1.5rem;\n}\n.article-content :deep(h2) {\n  margin-top: 2.5rem;\n  margin-bottom: 1rem;\n  font-size: 1.75rem;\n}\n.article-content :deep(h3) {\n  margin-top: 2rem;\n  margin-bottom: 0.75rem;\n  font-size: 1.25rem;\n}\n</style>\n","<template>\n  <div>\n    <!-- Perspective Header -->\n    <div class=\"mb-12 pb-8 border-b-2 border-accent\">\n      <div class=\"text-xs uppercase tracking-wider text-accent mb-3 font-bold\">Perspective</div>\n      <h1 class=\"font-serif text-6xl font-bold mb-6 leading-tight\">{{ content.title }}</h1>\n      <p v-if=\"content.subtitle\" class=\"text-2xl text-muted mb-6\">{{ content.subtitle }}</p>\n      <div class=\"flex justify-between items-baseline\">\n        <div>\n          <p class=\"text-muted text-sm mb-2\">By <span class=\"font-bold\">{{ content.author || 'Editorial Team' }}</span></p>\n          <p class=\"text-muted text-sm\">{{ formatDate(content.date) }}</p>\n        </div>\n        <span v-if=\"content.category\" class=\"bg-accent text-white text-xs px-3 py-1 font-sans\">{{ content.category }}</span>\n      </div>\n    </div>\n\n    <!-- Perspective Content -->\n    <div class=\"perspective-content prose prose-xl max-w-none mb-16\">\n      <ContentRenderer :value=\"content\" />\n    </div>\n\n    <!-- Perspective Footer -->\n    <div class=\"mt-16 pt-8 border-t-2 border-accent\">\n      <div class=\"bg-accent text-white p-8 rounded\">\n        <h3 class=\"font-serif text-xl font-bold mb-3\">This Perspective</h3>\n        <p class=\"text-sm\">{{ content.summary || 'An exploration of context, nuance, and multiple viewpoints on this topic.' }}</p>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script setup lang=\"ts\">\ndefineProps<{\n  content: any\n}>()\n\nconst formatDate = (date: string) => {\n  if (!date) return ''\n  return new Date(date).toLocaleDateString('en-US', { \n    year: 'numeric', \n    month: 'long', \n    day: 'numeric' \n  })\n}\n</script>\n\n<style scoped>\n.border-accent {\n  border-color: #1a1a1a;\n}\n.text-accent {\n  color: #1a1a1a;\n}\n.bg-accent {\n  background-color: #1a1a1a;\n}\n.text-muted {\n  color: #666666;\n}\n.perspective-content {\n  line-height: 1.8;\n  font-size: 1.125rem;\n}\n.perspective-content :deep(p) {\n  margin-bottom: 2rem;\n}\n.perspective-content :deep(h2) {\n  margin-top: 3rem;\n  margin-bottom: 1.5rem;\n  font-size: 2rem;\n}\n</style>\n","<template>\n  <div>\n    <!-- Book Header -->\n    <div class=\"mb-12 text-center\">\n      <div class=\"text-xs uppercase tracking-wider text-muted mb-3\">Book</div>\n      <h1 class=\"font-serif text-5xl font-bold mb-4 leading-tight\">{{ content.title }}</h1>\n      <p v-if=\"content.author\" class=\"text-xl text-muted mb-2\">by {{ content.author }}</p>\n      <p v-if=\"content.year\" class=\"text-sm text-muted mb-6\">({{ content.year }})</p>\n      <div v-if=\"content.image\" class=\"max-w-md mx-auto mb-8\">\n        <img :src=\"content.image\" :alt=\"content.title\" class=\"w-full shadow-lg\" />\n      </div>\n    </div>\n\n    <!-- Book Content -->\n    <div class=\"book-content prose prose-lg max-w-none mb-16\">\n      <ContentRenderer :value=\"content\" />\n    </div>\n\n    <!-- Book Metadata -->\n    <div v-if=\"content.isbn || content.publisher\" class=\"mt-16 pt-8 border-t border-accent\">\n      <div class=\"bg-light p-6 rounded text-sm\">\n        <h3 class=\"font-serif text-base font-bold mb-3\">Publication Details</h3>\n        <p v-if=\"content.publisher\" class=\"mb-1\"><strong>Publisher:</strong> {{ content.publisher }}</p>\n        <p v-if=\"content.isbn\" class=\"mb-1\"><strong>ISBN:</strong> {{ content.isbn }}</p>\n        <p v-if=\"content.pages\" class=\"mb-1\"><strong>Pages:</strong> {{ content.pages }}</p>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script setup lang=\"ts\">\ndefineProps<{\n  content: any\n}>()\n</script>\n\n<style scoped>\n.border-accent {\n  border-color: #1a1a1a;\n}\n.text-muted {\n  color: #666666;\n}\n.bg-light {\n  background-color: #F5F5F5;\n}\n.book-content {\n  line-height: 1.7;\n}\n</style>\n","<template>\n  <div>\n    <!-- Page Header -->\n    <div class=\"mb-12 pb-8 border-b border-accent\">\n      <h1 class=\"font-serif text-4xl font-bold mb-4 leading-tight\">{{ content.title }}</h1>\n      <p v-if=\"content.description\" class=\"text-lg text-muted\">{{ content.description }}</p>\n    </div>\n\n    <!-- Page Content -->\n    <div class=\"page-content prose prose-lg max-w-none\">\n      <ContentRenderer :value=\"content\" />\n    </div>\n  </div>\n</template>\n\n<script setup lang=\"ts\">\ndefineProps<{\n  content: any\n}>()\n</script>\n\n<style scoped>\n.border-accent {\n  border-color: #1a1a1a;\n}\n.text-muted {\n  color: #666666;\n}\n.page-content {\n  line-height: 1.7;\n}\n</style>\n","<template>\n  <div>\n    <!-- Person Header -->\n    <div class=\"mb-12 text-center\">\n      <div v-if=\"content.image\" class=\"mb-6\">\n        <img :src=\"content.image\" :alt=\"content.title\" class=\"w-32 h-32 rounded-full mx-auto object-cover\" />\n      </div>\n      <h1 class=\"font-serif text-4xl font-bold mb-2\">{{ content.title }}</h1>\n      <p v-if=\"content.role\" class=\"text-lg text-muted mb-4\">{{ content.role }}</p>\n      <div v-if=\"content.social\" class=\"flex justify-center gap-4 text-sm\">\n        <a v-if=\"content.social.twitter\" :href=\"content.social.twitter\" class=\"text-accent hover:underline\">Twitter</a>\n        <a v-if=\"content.social.linkedin\" :href=\"content.social.linkedin\" class=\"text-accent hover:underline\">LinkedIn</a>\n        <a v-if=\"content.social.website\" :href=\"content.social.website\" class=\"text-accent hover:underline\">Website</a>\n      </div>\n    </div>\n\n    <!-- Bio Content -->\n    <div class=\"person-content prose prose-lg max-w-none mb-16\">\n      <ContentRenderer :value=\"content\" />\n    </div>\n\n    <!-- Articles by this person (if available) -->\n    <div class=\"mt-16 pt-8 border-t border-accent\">\n      <h3 class=\"font-serif text-xl font-bold mb-4\">Contributions</h3>\n      <p class=\"text-sm text-muted\">Articles and perspectives by {{ content.title }} will appear here.</p>\n    </div>\n  </div>\n</template>\n\n<script setup lang=\"ts\">\ndefineProps<{\n  content: any\n}>()\n</script>\n\n<style scoped>\n.border-accent {\n  border-color: #1a1a1a;\n}\n.text-accent {\n  color: #1a1a1a;\n}\n.text-muted {\n  color: #666666;\n}\n.person-content {\n  line-height: 1.7;\n}\n</style>\n","<template>\n  <div>\n    <!-- Language Header -->\n    <div class=\"mb-12 pb-8 border-b border-accent text-center\">\n      <div class=\"text-6xl mb-4\">🌐</div>\n      <h1 class=\"font-serif text-4xl font-bold mb-2\">{{ content.title }}</h1>\n      <p v-if=\"content.code\" class=\"text-sm text-muted uppercase tracking-wider\">Language Code: {{ content.code }}</p>\n    </div>\n\n    <!-- Language Content -->\n    <div class=\"language-content prose prose-lg max-w-none mb-16\">\n      <ContentRenderer :value=\"content\" />\n    </div>\n\n    <!-- Available Content -->\n    <div class=\"mt-16 pt-8 border-t border-accent\">\n      <h3 class=\"font-serif text-xl font-bold mb-4\">Content in {{ content.title }}</h3>\n      <p class=\"text-sm text-muted\">Articles, perspectives, and pages available in this language will be listed here.</p>\n    </div>\n  </div>\n</template>\n\n<script setup lang=\"ts\">\ndefineProps<{\n  content: any\n}>()\n</script>\n\n<style scoped>\n.border-accent {\n  border-color: #1a1a1a;\n}\n.text-muted {\n  color: #666666;\n}\n.language-content {\n  line-height: 1.7;\n}\n</style>\n","<template>\n  <main class=\"max-w-4xl mx-auto px-4 sm:px-6 py-12 sm:py-16\">\n    <article v-if=\"content\">\n      <!-- Dynamic content rendering based on type -->\n      <component :is=\"templateComponent\" :content=\"content\" />\n    </article>\n    <div v-else class=\"text-center py-12\">\n      <p>Content not found</p>\n    </div>\n  </main>\n</template>\n\n<script setup lang=\"ts\">\nimport ArticleTemplate from '~/components/magazine/ArticleTemplate.vue'\nimport PerspectiveTemplate from '~/components/magazine/PerspectiveTemplate.vue'\nimport BookTemplate from '~/components/magazine/BookTemplate.vue'\nimport PageTemplate from '~/components/magazine/PageTemplate.vue'\nimport PersonTemplate from '~/components/magazine/PersonTemplate.vue'\nimport LanguageTemplate from '~/components/magazine/LanguageTemplate.vue'\n\ndefinePageMeta({\n  layout: 'default'\n})\n\nconst route = useRoute()\nconst type = route.params.type as string\nconst slug = route.params.slug as string\n\n// Get content type info\nconst contentType = await getContentTypeBySingular(type)\nif (!contentType) {\n  throw createError({ statusCode: 404, message: 'Content type not found' })\n}\n\n// Fetch content\nconst { data: content } = await useAsyncData(\n  `${type}-${slug}`,\n  () => queryContent(`/${contentType.folder}/${slug}`).findOne()\n)\n\n// Map type to template component\nconst templateMap: Record<string, any> = {\n  article: ArticleTemplate,\n  perspective: PerspectiveTemplate,\n  book: BookTemplate,\n  page: PageTemplate,\n  person: PersonTemplate,\n  language: LanguageTemplate\n}\n\nconst templateComponent = computed(() => {\n  return templateMap[type] || PageTemplate // fallback to page template\n})\n\n// SEO - dynamic based on content type\nwatch(() => content.value, (newContent) => {\n  if (newContent) {\n    const imageUrl = newContent.image || '/og-default.png'\n    const publishedDate = newContent.date ? new Date(newContent.date).toISOString() : new Date().toISOString()\n    \n    useSeoMeta({\n      title: `${newContent.title} | Everything in Perspective`,\n      description: newContent.description,\n      ogTitle: newContent.title,\n      ogDescription: newContent.description,\n      ogType: type === 'article' || type === 'perspective' ? 'article' : 'website',\n      ogImage: imageUrl,\n      ogImageAlt: newContent.imageAlt || newContent.title,\n      twitterCard: 'summary_large_image',\n      twitterImage: imageUrl\n    })\n    \n    // Schema based on type\n    const schemaType = type === 'article' || type === 'perspective' ? 'NewsArticle' : \n                       type === 'book' ? 'Book' :\n                       type === 'person' ? 'Person' : 'WebPage'\n    \n    useHead({\n      script: [\n        {\n          type: 'application/ld+json',\n          innerHTML: JSON.stringify({\n            '@context': 'https://schema.org',\n            '@type': schemaType,\n            headline: newContent.title,\n            description: newContent.description,\n            image: imageUrl,\n            author: newContent.author ? {\n              '@type': 'Person',\n              name: newContent.author\n            } : undefined,\n            publisher: {\n              '@type': 'Organization',\n              name: 'Everything in Perspective',\n              logo: {\n                '@type': 'ImageObject',\n                url: 'https://einp.surge.sh/logo.png',\n                width: 250,\n                height: 60\n              }\n            },\n            datePublished: publishedDate,\n            dateModified: publishedDate\n          })\n        }\n      ]\n    })\n  }\n}, { immediate: true })\n</script>\n"],"version":3}
{
  "name": "everythinginperspective",
  "version": "1.0.0",
  "description": "A magazine exploring trends in perspective",
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "generate": "nuxt generate && rm -rf docs && cp -r .output/public docs && pagefind --site docs",
    "dev": "nuxt dev",
    "start": "nuxt preview",
    "deploy": "npm run generate && git add docs && git commit -m 'Deploy to GitHub Pages' && git push origin main"
  },

    "@nuxtjs/sitemap": "^8.0.0",
    "better-sqlite3": "^12.9.0",
    "nuxt": "^4.4.4",
    "nuxt-ai-ready": "^1.3.0",
    "nuxt-og-image": "6.5.0",
    "nuxt-schema-org": "6.0.4",
    "nuxt-seo-utils": "8.1.11",
    "nuxt-skew-protection": "1.1.1",
    "pagefind": "^1.5.2",
